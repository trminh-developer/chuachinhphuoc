{
  "version": 2,
  "builds": [
    { "src": "src/server.ts", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "googledca5cf6bdd3e460e.html", "use": "@vercel/static" },
    { "src": "event.html", "use": "@vercel/static" },
    { "src": "logo.jpg", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" },
    { "src": "manifest-admin.json", "use": "@vercel/static" },
    { "src": "sw.js", "use": "@vercel/static" },
    { "src": "Admin/admin.html", "use": "@vercel/static" },
    { "src": "styles/**", "use": "@vercel/static" },
    { "src": "scripts/**", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/server.ts" },
    { "src": "/logo.jpg", "dest": "logo.jpg" },
    { "src": "/manifest.json", "dest": "manifest.json" },
    { "src": "/manifest-admin.json", "dest": "manifest-admin.json" },
    { "src": "/sw.js", "dest": "sw.js" },
    { "src": "/admin", "dest": "Admin/admin.html" },
    { "src": "/Admin/admin.html", "dest": "Admin/admin.html" },
    { "src": "/googledca5cf6bdd3e460e.html", "dest": "googledca5cf6bdd3e460e.html" },
    { "src": "/event.html", "dest": "event.html" },
    { "src": "/styles/(.*)", "dest": "styles/$1" },
    { "src": "/scripts/(.*)", "dest": "scripts/$1" },
    { "src": "/public/(.*)", "dest": "public/$1" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}