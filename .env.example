# SQL Server Configuration
# For Windows Authentication, leave DB_USER and DB_PASSWORD empty
# For SQL Authentication, provide DB_USER and DB_PASSWORD with appropriate values
DB_HOST=TrMinh
DB_USER=sa
DB_PASSWORD=YourSecurePassword123!
DB_NAME=pagoda_website

# Database Configuration (Vercel Postgres / Supabase)
# Dán đường link Database (POSTGRES_URL) do Vercel/Supabase cung cấp vào đây.
POSTGRES_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Server Configuration
PORT=3001
NODE_ENV=development

# JSON Web Token Secret
JWT_SECRET=thay_bang_chuoi_bi_mat_cua_ban_123456 - CHANGE THIS IN PRODUCTION
JWT_SECRET=your-super-secret-key-change-this-in-production-use-a-strong-random-string
